        RowBox[{
         RowBox[{
          RowBox[{"\\", "bar"}], 
          RowBox[{"{", "z", "}"}], "_", "5"}], ";"}], "\\", "epsilon"}]}], 
      ")"}]}], ",", " ", 
    RowBox[{"respectively", "."}]}], "*)"}]}]], "Input",
