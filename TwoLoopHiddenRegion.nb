                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}]}],
                  ")"}], "^", "3"}]}], "]"}], "]"}], "+", 
