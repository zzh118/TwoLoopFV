Cell[BoxData[
 RowBox[{
  RowBox[{"Get", "[", "\"\<DeltaTimesAmp4pt.mx\>\"", "]"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "This", " ", "contains", " ", "the", " ", "result", " ", "of", " ", 
      RowBox[{"applying", " ", "\\", "mathbf"}], 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\\", "Delta"}], "}"}], "^", 
       RowBox[{"{", 
        RowBox[{"(", "2", ")"}], "}"}]}], " ", "to", " ", "the", " ", 
      "tree"}], "-", 
     RowBox[{"level", " ", "4"}], "-", 
     RowBox[{"point", " ", "amplitude", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\\", "cal"}], " ", "A"}], "}"}], "_", 
      RowBox[{"4", "^", 
       RowBox[{"{", 
        RowBox[{"(", "0", ")"}], "}"}]}]}]}], ",", " ", 
    RowBox[{
    "which", " ", "captures", " ", "all", " ", "x", " ", "and", " ", "y", " ",
      "dependence", " ", 
     RowBox[{"in", " ", "\\", "mathbf"}], 
     RowBox[{
      RowBox[{"{", "Sp", "}"}], "^", 
      RowBox[{"{", 
       RowBox[{"(", "2", ")"}], "}"}]}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\\", "cal"}], " ", "A"}], "}"}], "_", 
     RowBox[{
      RowBox[{"4", "^", 
       RowBox[{"{", 
        RowBox[{"(", "0", ")"}], "}"}]}], ".", " ", "The"}], " ", "result", 
     " ", "is", " ", "stored", " ", "with", " ", "the", " ", "name", " ", 
     "\"\<DeltaTimesAmp4pt\>\"", " ", "where", " ", "g4", " ", "and", " ", 
     "g5", " ", "represents", " ", "g_", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\\", "vec"}], 
       RowBox[{"{", 
        RowBox[{"\\", "lambda"}], "}"}]}], "}"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"z_", "4"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\\", "bar"}], 
          RowBox[{"{", "z", "}"}], "_", "4"}], ";"}], "\\", "epsilon"}]}], 
      ")"}], " ", "and", " ", "g_", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\\", "vec"}], 
       RowBox[{"{", 
        RowBox[{"\\", "lambda"}], "}"}]}], "}"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"z_", "5"}], ",", 
