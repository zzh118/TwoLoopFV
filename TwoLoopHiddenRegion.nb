                  RowBox[{"1", ",", 
                   RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}]}],
                 ")"}], "^", "2"}]}], "]"}], "]"}], "+", 
           RowBox[{"G", "[", 
            RowBox[{"0", ",", "0", ",", 
             RowBox[{
              FractionBox["1", "2"], " ", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}]}]}], 
         "}"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"G", "[", 
          RowBox[{"0", ",", 
           RowBox[{
            FractionBox["1", "2"], " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], "->", 
