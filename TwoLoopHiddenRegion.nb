          RowBox[{"G", "[", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{
             FractionBox["1", "2"], " ", 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], "->", 
          
          RowBox[{
           RowBox[{
            FractionBox["1", "2"], 
            RowBox[{
             RowBox[{"Log", "[", 
              FractionBox[
               RowBox[{" ", 
                RowBox[{"(", 
                 RowBox[{"1", "+", 
                  RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}], 
               RowBox[{" ", 
                RowBox[{"(", 
                 RowBox[{"1", "-", 
                  RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]], "]"}], "^",
              "2"}]}], "-", 
           RowBox[{"ExtractZeroes", "[", 
            RowBox[{"ShuffleG", "[", 
             RowBox[{
              FractionBox["1", "2"], 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"G", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], 
