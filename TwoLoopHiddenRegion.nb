b68fb263c268"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RepConv", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"xp", "->", 
     FractionBox[
      RowBox[{"-", "x"}], 
      RowBox[{"x", "+", "1"}]]}], ",", 
    RowBox[{"eps50", "->", 
     RowBox[{"4", "I", " ", "s", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"s", 
        RowBox[{"(", 
         RowBox[{"-", "x"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"x", "+", "1"}], ")"}], "z", 
        RowBox[{"(", 
         RowBox[{"z", "-", "1"}], ")"}]}], "]"}], "*", 
      FractionBox[
       RowBox[{"1", "-", 
        RowBox[{"y", "^", "2"}]}], 
       RowBox[{"1", "+", 
        RowBox[{"y", "^", "2"}]}]]}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.993039678527364*^9, 3.993039746461385*^9}},
 CellLabel->"In[92]:=",ExpressionUUID->"0b6f98ef-1005-44ed-964f-91c87bf987af"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"xp", "\[Rule]", 
    RowBox[{"-", 
     FractionBox["x", 
      RowBox[{"1", "+", "x"}]]}]}], ",", 
   RowBox[{"eps50", "\[Rule]", 
    FractionBox[
     RowBox[{"4", " ", "\[ImaginaryI]", " ", "s", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["y", "2"]}], ")"}], " ", 
      SqrtBox[
       RowBox[{
        RowBox[{"-", "s"}], " ", "x", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "x"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "z"}], ")"}], " ", "z"}]]}], 
     RowBox[{"1", "+", 
      SuperscriptBox["y", "2"]}]]}]}], "}"}]], "Output",
 CellChangeTimes->{3.99303974828478*^9},
 CellLabel->"Out[92]=",ExpressionUUID->"b70de484-4c18-4bd3-85c2-525ba6664e1b"]
}, Open  ]]
