Cell[BoxData[
 RowBox[{
  RowBox[{"DeltaTimesAmp4ptXY", "=", 
   RowBox[{"DeltaTimesAmp4pt", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"g4", "->", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            FractionBox["1", 
             RowBox[{"eps", "^", "2"}]], "-", 
            RowBox[{"Zeta", "[", "2", "]"}]}], ")"}]}], 
         RowBox[{"G", "[", 
          RowBox[{"0", ",", "xp"}], "]"}]}], "-", 
        RowBox[{
         FractionBox["2", "3"], " ", 
         SuperscriptBox["\[Pi]", "2"], " ", 
         RowBox[{"Log", "[", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", "-", "y"}], 
           RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}]}], "-", 
        RowBox[{"4", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
         SuperscriptBox[
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", "-", "y"}], 
            RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}], "2"]}], "-", 
        RowBox[{
         FractionBox["8", "3"], " ", 
         SuperscriptBox[
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", "-", "y"}], 
            RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}], "3"]}]}]}], ",", 
      RowBox[{"g5", "->", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{"eps", "^", "2"}]], "-", 
           RowBox[{"Zeta", "[", "2", "]"}]}], ")"}], 
         RowBox[{"G", "[", 
          RowBox[{"0", ",", "xp"}], "]"}]}], "-", 
        RowBox[{
         FractionBox["2", "3"], " ", 
         SuperscriptBox["\[Pi]", "2"], " ", 
         RowBox[{"Log", "[", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", "-", "y"}], 
           RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}]}], "+", 
        RowBox[{"4", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
         SuperscriptBox[
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", "-", "y"}], 
            RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}], "2"]}], "-", 
        RowBox[{
         FractionBox["8", "3"], " ", 
         SuperscriptBox[
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", "-", "y"}], 
            RowBox[{"\[ImaginaryI]", "+", "y"}]], "]"}], "3"]}]}]}]}], 
     "}"}]}]}], ";", 
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "plug", " ", "in", " ", "g4", " ", "and", " ", "g5", " ", "the",
     " ", "terms", " ", "involving", " ", "x", " ", "and", " ", "y", " ", 
    "of", " ", "g_", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\\", "vec"}], 
      RowBox[{"{", 
       RowBox[{"\\", "lambda"}], "}"}]}], "}"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"z_", "4"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\\", "bar"}], 
         RowBox[{"{", "z", "}"}], "_", "4"}], ";"}], "\\", "epsilon"}]}], 
     ")"}], " ", "and", " ", "g_", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\\", "vec"}], 
      RowBox[{"{", 
       RowBox[{"\\", "lambda"}], "}"}]}], "}"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"z_", "5"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\\", "bar"}], 
          RowBox[{"{", "z", "}"}], "_", "5"}], ";"}], "\\", "epsilon"}]}], 
      ")"}], "."}]}], "*)"}]}]], "Input",
