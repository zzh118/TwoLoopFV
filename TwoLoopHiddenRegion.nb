Cell[BoxData[
 RowBox[{
  RowBox[{"AmpYdep", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"GCoefficientSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"ExtractZeroes", "[", 
          RowBox[{"GCoefficientSimplify", "[", 
           RowBox[{
            RowBox[{"Amp5pt", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Amp5pt", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "/.", 
              RowBox[{
               RowBox[{"G", "[", 
                RowBox[{"__", ",", 
                 RowBox[{
                  FractionBox["1", "2"], " ", 
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], "->",
                "0"}]}], ")"}]}], "]"}], "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"G", "[", 
            RowBox[{"0", ",", "0", ",", "0", ",", 
             RowBox[{
              FractionBox["1", "2"], " ", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], "->", 
           RowBox[{
            RowBox[{
             FractionBox["1", "6"], 
             RowBox[{
              RowBox[{"Log", "[", 
               FractionBox[
                RowBox[{" ", 
                 RowBox[{"(", 
                  RowBox[{"1", "+", 
                   RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}], 
                RowBox[{" ", 
                 RowBox[{"(", 
                  RowBox[{"1", "-", 
                   RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]], "]"}], 
              "^", "3"}]}], "-", 
            RowBox[{"ExtractZeroes", "[", 
             RowBox[{"ShuffleG", "[", 
              RowBox[{
               FractionBox["1", "6"], 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"G", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], 
                  "-", 
