Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RepSij", "=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"s12", "->", 
      RowBox[{"s", "*", "z"}]}], ",", 
     RowBox[{"s23", "->", 
      RowBox[{
       RowBox[{"-", "4"}], "*", 
       RowBox[{"\[Delta]", "^", "2"}]}]}], ",", 
     RowBox[{"s34", "->", 
      RowBox[{"s", "*", "x", "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "z"}], ")"}]}]}], ",", 
     RowBox[{"s45", "->", "s"}], ",", 
     RowBox[{"s15", "->", 
      RowBox[{
       RowBox[{"x", "*", "s"}], "+", 
       RowBox[{"c", "*", "\[Delta]"}]}]}]}], "}"}], "/.", 
   RowBox[{"{", 
    RowBox[{"c", "->", 
     RowBox[{
      FractionBox[
       RowBox[{"8", "y"}], 
       RowBox[{"1", "+", 
        RowBox[{"y", "^", "2"}]}]], 
      RowBox[{"Sqrt", "[", 
       FractionBox[
        RowBox[{"s", 
         RowBox[{"(", 
          RowBox[{"-", "x"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"x", "+", "1"}], ")"}], "z"}], 
        RowBox[{"z", "-", "1"}]], "]"}]}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.993039546863359*^9, 3.9930396359363003`*^9}},
 CellLabel->"In[91]:=",ExpressionUUID->"246ed57b-9530-4b40-b48c-15b3707e9774"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"s12", "\[Rule]", 
    RowBox[{"s", " ", "z"}]}], ",", 
   RowBox[{"s23", "\[Rule]", 
    RowBox[{
     RowBox[{"-", "4"}], " ", 
     SuperscriptBox["\[Delta]", "2"]}]}], ",", 
   RowBox[{"s34", "\[Rule]", 
    RowBox[{"s", " ", "x", " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", "z"}], ")"}]}]}], ",", 
   RowBox[{"s45", "\[Rule]", "s"}], ",", 
   RowBox[{"s15", "\[Rule]", 
    RowBox[{
     RowBox[{"s", " ", "x"}], "+", 
     FractionBox[
      RowBox[{"8", " ", "y", " ", 
       SqrtBox[
        RowBox[{"-", 
         FractionBox[
          RowBox[{"s", " ", "x", " ", 
           RowBox[{"(", 
            RowBox[{"1", "+", "x"}], ")"}], " ", "z"}], 
          RowBox[{
           RowBox[{"-", "1"}], "+", "z"}]]}]], " ", "\[Delta]"}], 
      RowBox[{"1", "+", 
       SuperscriptBox["y", "2"]}]]}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.99303963816844*^9},
 CellLabel->"Out[91]=",ExpressionUUID->"b2bcfe16-81b7-4936-b2e6-e717f861df3c"]
}, Open  ]],

