Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "<=", 
    RowBox[{"Length", "[", "Amp5pt", "]"}]}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"GCoefficientSimplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"ExtractZeroes", "[", 
           RowBox[{"Amp5pt", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"G", "[", 
             RowBox[{"0", ",", "0", ",", "0", ",", 
              RowBox[{
               FractionBox["1", "2"], " ", 
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], "->", 
            RowBox[{
             RowBox[{
              FractionBox["1", "6"], 
              RowBox[{
               RowBox[{"Log", "[", 
                FractionBox[
                 RowBox[{" ", 
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}], 
                 RowBox[{" ", 
                  RowBox[{"(", 
                   RowBox[{"1", "-", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]], "]"}], 
               "^", "3"}]}], "-", 
             RowBox[{"ExtractZeroes", "[", 
              RowBox[{"ShuffleG", "[", 
               RowBox[{
                FractionBox["1", "6"], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"G", "[", 
                    RowBox[{"0", ",", 
                    RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}], 
                   "-", 
                   RowBox[{"G", "[", 
                    RowBox[{"1", ",", 
                    RowBox[{
                    FractionBox["1", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"\[ImaginaryI]", " ", "y"}]}], ")"}]}]}], "]"}]}],
                   ")"}], "^", "3"}]}], "]"}], "]"}], "+", 
